# ============================================================
# SentientMarkets Sentiment API — environment variables
# ============================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit secrets.
#
# Variable categories
#   [DB]       Infrastructure (Postgres, Redis) — required for any live run
#   [API]      Third-party data-source keys     — required for the live pipeline,
#                                                 not required for `pytest` unit tests
#   [AUTH]     API-key generation helpers
#   [LOG]      Logging configuration            — optional, sensible defaults
#   [PLANNED]  Listed for completeness; not currently read by any code path
# ============================================================


# --- [DB] PostgreSQL --------------------------------------------------------
# SQLAlchemy-style URL accepted; `db/connection.py` strips the `+asyncpg`
# dialect before handing it to asyncpg.
#
# Format:  postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=


# --- [DB] Redis -------------------------------------------------------------
# Used as the current-state cache (key `sentiment:{ticker}`) and for the
# per-key sliding-window rate limiter.
#
# Format:  redis://[:PASSWORD@]HOST:PORT[/DB_NUMBER]
REDIS_URL=


# --- [API] Alpha Vantage ----------------------------------------------------
# Used by:
#   - pipeline/sources/narrative.py  (NEWS_SENTIMENT endpoint — text + relevance)
#   - pipeline/sources/macro.py      (VIX fallback)
#   - backfill/ohlcv_backfill.py     (one-time AV historical OHLCV backfill)
#   - backfill/etf_backfill.py       (one-time sector-ETF backfill)
# Premium-tier key required for TIME_SERIES_DAILY_ADJUSTED on backfill.
ALPHA_VANTAGE_KEY=


# --- [API] Finnhub ----------------------------------------------------------
# Used by:
#   - pipeline/sources/narrative.py    (/company-news — narrative fallback)
#   - pipeline/sources/influencer.py   (insider transactions, analyst-consensus)
#   - pipeline/sources/macro.py        (VIX secondary)
FINNHUB_KEY=


# --- [API] FRED (St. Louis Fed) ---------------------------------------------
# Used by pipeline/sources/fred.py for the three Treasury / yield-curve macro
# signals: DGS10 (10y), DGS2 (2y), T10Y2Y (10y−2y, TED-substitute).
FRED_API_KEY=


# --- [API] NewsAPI ----------------------------------------------------------
# [PLANNED] Listed in the v1 spec and Phase-2 plan but never wired into the
# current pipeline. The `newsapi` source weight was removed from
# `_SOURCE_WEIGHTS` (`normalize.py`) when the methodology was finalised to
# AV + Finnhub + FinBERT. Kept as a placeholder for an eventual re-introduction.
NEWSAPI_KEY=


# --- [API] OpenAI -----------------------------------------------------------
# [PLANNED] Reserved for the Pro-tier explanation endpoint (GPT-4o-mini
# grounded on the structured driver schema). Not currently called from any
# code path — the template-based explanation in
# `pipeline/explanation/templates.py` handles both tiers today.
OPENAI_API_KEY=


# --- [AUTH] Generated API keys ---------------------------------------------
# `tools/generate_keys.py` mints one Pro and one Free API key, prints the
# plaintext once, and stores SHA-256 hashes in the `api_keys` table. The
# generator does NOT read these env vars today — they are listed here as the
# canonical place to record the keys after generation, for ops handoff.
# Format expected by the API: `sk-sm-prod-...` (Pro), `sk-sm-dev-...` (Free).
PRO_API_KEY=
FREE_API_KEY=


# --- [LOG] Logging configuration --------------------------------------------
# LOG_LEVEL : DEBUG | INFO | WARNING | ERROR  (default INFO)
# LOG_FORMAT: json | text                      (json in Railway; text locally)
LOG_LEVEL=INFO
LOG_FORMAT=text
